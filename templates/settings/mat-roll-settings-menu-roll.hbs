<section class='tab roll scrollable {{tab.cssClass}}' data-group='primary' data-tab='roll'>
    <div class="settings-list">
        {{#each this.settings.roll}}
        <div class="form-group">
            {{#with this}}
            {{#if this.client}}
            {{> mat.setting}}
            {{/if}}
            {{/with}}
        </div>
        {{/each}}
    </div>
</section>