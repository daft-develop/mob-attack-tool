<section class='tab module scrollable {{tab.cssClass}}' data-group='primary' data-tab='module'>
    {{#if this.isGM}}
    <div class="settings-list">
        {{#each this.settings.module}}
        <div class="form-group">
            {{#with this}}
            {{#if this.client}}
            {{> mat.setting}}
            {{/if}}
            {{/with}}
        </div>
        {{/each}}
    </div>
    {{/if}}
</section>